# Default behavior: auto-detect text files and normalize line endings to LF on commit.
# Working copy on all platforms will check out with LF.
* text=auto eol=lf

# Explicitly mark common text files as LF (defense in depth)
*.js          text eol=lf
*.mjs         text eol=lf
*.cjs         text eol=lf
*.ts          text eol=lf
*.json        text eol=lf
*.jsonc       text eol=lf
*.html        text eol=lf
*.css         text eol=lf
*.md          text eol=lf
*.yml         text eol=lf
*.yaml        text eol=lf
*.toml        text eol=lf
*.sh          text eol=lf
*.cs          text eol=lf
*.csproj      text eol=lf
*.sln         text eol=lf

# Windows-only scripts keep CRLF
*.bat         text eol=crlf
*.cmd         text eol=crlf
*.ps1         text eol=crlf

# Binary files (do not normalize)
*.png         binary
*.jpg         binary
*.jpeg        binary
*.gif         binary
*.ico         binary
*.webp        binary
*.svg         binary
*.pdf         binary
*.zip         binary
*.gz          binary
*.woff        binary
*.woff2       binary
*.ttf         binary
*.otf         binary
*.eot         binary
